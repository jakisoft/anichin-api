<%- include('partials/header', { title: title, description: description, currentUrl: currentUrl, ogImage: ogImage, ogType: 'website' }) %>

<section class="space-y-4" data-aos="fade-up">
    <!-- Breadcrumb Path Navigation -->
    <nav class="flex items-center gap-1.5 sm:gap-2 text-xs font-extrabold text-saweria-dark bg-white border-2 border-saweria-dark px-3.5 sm:px-4 py-2 rounded-2xl shadow-[2px_2px_0_#1e1e1e] w-full max-w-full flex-wrap overflow-hidden leading-normal">
        <a href="/" class="hover:text-saweria-coral flex items-center gap-1 transition-colors flex-shrink-0">
            <i data-lucide="home" class="w-3.5 h-3.5"></i> Beranda
        </a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-saweria-gray flex-shrink-0"></i>

        <% 
            let cleanTitle = pageTitle.replace(/\s*\(Halaman\s*\d+\)/i, '').replace(/^Genre\s*\/\s*Kategori:\s*/i, '');
            let cleanBaseUrl = typeof baseUrl !== 'undefined' && baseUrl ? baseUrl : (typeof currentUrl !== 'undefined' ? currentUrl.replace(/[\?&]page=\d+.*/i, '').replace(/\/page\/\d+.*/i, '') : '/');
            if (!cleanBaseUrl || cleanBaseUrl === '') cleanBaseUrl = '/';
        %>

        <% if (typeof genreName !== 'undefined') { %>
            <a href="/genres" class="hover:text-saweria-coral flex items-center gap-1 transition-colors flex-shrink-0">
                <i data-lucide="tags" class="w-3.5 h-3.5"></i> Kategori Genre
            </a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-saweria-gray flex-shrink-0"></i>
            <a href="<%= cleanBaseUrl %>" class="hover:text-saweria-coral font-black max-w-[120px] sm:max-w-[220px] truncate" title="# <%= genreName %>">
                # <%= genreName %>
            </a>
            <% if (typeof currentPage !== 'undefined' && currentPage) { %>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-saweria-gray flex-shrink-0"></i>
            <span class="text-saweria-coral font-black flex-shrink-0">Halaman <%= currentPage %></span>
            <% } %>
        <% } else { %>
            <a href="<%= cleanBaseUrl %>" class="hover:text-saweria-coral font-black max-w-[150px] sm:max-w-[300px] truncate" title="<%= cleanTitle %>">
                <%= cleanTitle %>
            </a>
            <% if (typeof currentPage !== 'undefined' && currentPage) { %>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-saweria-gray flex-shrink-0"></i>
            <span class="text-saweria-coral font-black flex-shrink-0">Halaman <%= currentPage %></span>
            <% } %>
        <% } %>
    </nav>

    <!-- Header Banner Title -->
    <div class="neo-card bg-saweria-yellow border-4 border-saweria-dark rounded-3xl p-5 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="space-y-1">
            <h1 class="text-xl sm:text-2xl font-extrabold text-saweria-dark"><%= cleanTitle %></h1>
            <p class="text-xs font-bold text-saweria-dark/80">Koleksi Donghua Subtitle Indonesia berkualitas HD.</p>
        </div>

        <div class="flex items-center gap-2">
            <span class="px-3 py-1 bg-white border-2 border-saweria-dark rounded-full text-xs font-extrabold text-saweria-dark">
                Halaman <%= currentPage %>
            </span>
        </div>
    </div>

    <!-- Items Grid -->
    <% if (items && items.length > 0) { %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3.5 sm:gap-4">
        <% items.forEach(item => { 
            let slug = item.href ? item.href.replace(/\/+$/, '').split('/').pop() : '';
            let isEpLink = slug.includes('-episode-') || slug.includes('episode');
            let targetUrl = isEpLink ? ('/watch/' + slug) : ('/detail/' + slug);
        %>
        <div class="neo-card bg-white border-3 border-saweria-dark rounded-2xl p-2.5 space-y-2 flex flex-col h-full neo-card-hover group">
            <div class="relative aspect-[3/4] rounded-xl overflow-hidden border-2 border-saweria-dark bg-saweria-bg flex-shrink-0">
                <img src="<%= item.image || 'https://via.placeholder.com/300x400' %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" alt="<%= item.title %>">
                
                <% if (item.ep) { %>
                <span class="absolute top-1.5 left-1.5 bg-saweria-yellow text-saweria-dark font-extrabold text-[9px] px-2 py-0.5 rounded-full border border-saweria-dark shadow-[1px_1px_0_#1e1e1e]">
                    <%= item.ep %>
                </span>
                <% } %>

                <% if (item.status) { %>
                <span class="absolute bottom-1.5 right-1.5 bg-saweria-green text-saweria-dark font-extrabold text-[9px] px-1.5 py-0.5 rounded-full border border-saweria-dark">
                    <%= item.status %>
                </span>
                <% } %>
            </div>

            <div class="flex-1 flex flex-col justify-between space-y-2">
                <a href="<%= targetUrl %>" class="font-extrabold text-xs text-saweria-dark group-hover:text-saweria-coral line-clamp-2 leading-tight">
                    <%= item.title %>
                </a>

                <div class="pt-2 border-t border-saweria-dark/10">
                    <a href="<%= targetUrl %>" class="neo-btn w-full text-center py-1 rounded-xl bg-saweria-yellow border-2 border-saweria-dark text-[10px] font-extrabold text-saweria-dark block">
                        <%= isEpLink ? 'Nonton Episode' : 'Lihat Detail' %>
                    </a>
                </div>
            </div>
        </div>
        <% }); %>
    </div>

    <!-- Pagination Nav -->
    <div class="flex items-center justify-center gap-3 pt-6">
        <% if (pagination && pagination.prev_page) { %>
        <a href="<%= baseUrl %>?page=<%= currentPage - 1 %>" class="neo-btn px-5 py-2 rounded-full bg-saweria-pink border-3 border-saweria-dark text-xs font-extrabold text-saweria-dark">
            &larr; Halaman Sebelumnya
        </a>
        <% } %>

        <% if (pagination && pagination.next_page) { %>
        <a href="<%= baseUrl %>?page=<%= currentPage + 1 %>" class="neo-btn px-5 py-2 rounded-full bg-saweria-green border-3 border-saweria-dark text-xs font-extrabold text-saweria-dark">
            Halaman Selanjutnya &rarr;
        </a>
        <% } %>
    </div>
    <% } else { %>
    <div class="neo-card bg-white border-4 border-saweria-dark rounded-3xl p-8 text-center space-y-3">
        <i data-lucide="search-x" class="w-10 h-10 text-saweria-coral mx-auto"></i>
        <h3 class="text-base font-extrabold text-saweria-dark">Tidak Ada Donghua Ditemukan</h3>
        <p class="text-xs font-bold text-saweria-gray">Coba kata kunci lain atau periksa kembali kategori halaman.</p>
    </div>
    <% } %>
</section>

<%- include('partials/footer') %>
