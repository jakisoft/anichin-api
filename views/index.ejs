        const pastelColors = [
            'bg-saweria-pink',
            'bg-saweria-blue',
            'bg-saweria-green',
            'bg-saweria-lavender'
        ];

        let activeEndpointIndex = 0;
        let activeLanguage = 'curl';

        document.getElementById('host-indicator').innerText = currentHost;

        async function loadGithubRepositoryStats() {
            try {
                const response = await fetch('https://api.github.com/repos/jakisoft/anichin-api');
                if (response.ok) {
                    const data = await response.json();
                    document.getElementById('github-stars').innerText = `${data.stargazers_count.toLocaleString()} Stars`;
                    document.getElementById('github-forks').innerText = `${data.forks_count.toLocaleString()} Forks`;
                } else {
                    useFallbackGithubStats();
                }
            } catch (err) {
                useFallbackGithubStats();
            }
        }

        function useFallbackGithubStats() {
            document.getElementById('github-stars').innerText = "142 Stars";
            document.getElementById('github-forks').innerText = "38 Forks";
        }

        function renderEndpoints() {
            const container = document.getElementById('endpoints-list');
            container.innerHTML = "";

            apiData.forEach((ep, i) => {
                const card = document.createElement('div');
                const assignedPastelColor = pastelColors[i % pastelColors.length];
                card.className = `neo-card ${assignedPastelColor} border-4 border-saweria-dark p-6 flex flex-col justify-between relative`;
                
                card.setAttribute('data-aos', 'fade-up');
                card.setAttribute('data-aos-delay', `${(i % 3) * 100}`);

                let paramIndicator = "";
                if (ep.params.length > 0) {
                    paramIndicator = `
                        <span class="inline-flex items-center gap-1 bg-white border-2 border-saweria-dark px-2 py-0.5 text-[10px] font-bold font-mono">
                            <i data-lucide="sliders" class="w-3 h-3"></i>
                            <span>${ep.params.length} Params</span>
                        </span>
                    `;
                }

                card.innerHTML = `
                    <div class="space-y-3">
                        <div class="flex items-center justify-between gap-2 border-b-2 border-saweria-dark pb-3">
                            <div class="flex items-center gap-2">
                                <h3 class="font-extrabold text-base text-saweria-dark tracking-tight leading-none">${ep.title}</h3>
                                ${paramIndicator}
                            </div>
                            <span class="bg-white text-saweria-dark border-2 border-saweria-dark px-2.5 py-0.5 text-[9px] font-extrabold tracking-wider font-mono">
                                ${ep.method}
                            </span>
                        </div>
                        
                        <p class="text-xs text-saweria-dark font-semibold leading-relaxed min-h-[40px]">${ep.description}</p>
                        
                        <div class="bg-white border-2 border-saweria-dark p-2.5 font-mono text-[11px] text-saweria-dark overflow-x-auto whitespace-nowrap scrollbar-none">
                            ${ep.path}
                        </div>
                    </div>

                    <div class="mt-6 flex justify-end">
                        <button onclick="openSandboxDrawer(${i})" class="neo-btn flex items-center justify-center gap-1 bg-saweria-yellow border-2 border-saweria-dark text-saweria-dark font-extrabold text-[11px] px-3.5 py-2 select-none">
                            <i data-lucide="terminal" class="w-3.5 h-3.5"></i>
                            <span>Buka Konsol Uji</span>
                        </button>
                    </div>
                `;
                container.appendChild(card);
            });
            lucide.createIcons();
        }

        function filterEndpoints(query) {
            const key = query.toLowerCase().trim();
            const cards = document.getElementById('endpoints-list').children;
            
            apiData.forEach((ep, i) => {
                const matches = ep.title.toLowerCase().includes(key) || ep.path.toLowerCase().includes(key);
                if (matches) {
                    cards[i].style.display = 'flex';
                } else {
                    cards[i].style.display = 'none';
                }
            });
        }

        function openSandboxDrawer(index) {
            activeEndpointIndex = index;
            const ep = apiData[index];

            document.getElementById('drawer-title').innerText = ep.title;
            document.getElementById('drawer-desc').innerText = ep.description;

            const paramsContainer = document.getElementById('drawer-params-container');
            const paramsForm = document.getElementById('drawer-params-form');
            
            if (ep.params.length > 0) {
                paramsContainer.classList.remove('hidden');
                paramsForm.innerHTML = ep.params.map(p => `
                    <div class="space-y-1.5">
                        <div class="flex justify-between font-mono text-[10px]">
                            <span class="text-saweria-dark font-extrabold">${p.name} <span class="text-saweria-gray">(${p.type})</span></span>
                            <span class="${p.required ? 'text-red-500 font-extrabold' : 'text-saweria-gray'}">${p.required ? 'Harus diisi' : 'Opsional'}</span>
                        </div>
                        <input type="text" id="sandbox-input-${p.name}" value="${p.default || ''}" oninput="updateInteractivePayloads()" class="w-full bg-white border-2 border-saweria-dark px-3 py-2 text-xs text-saweria-dark font-mono focus:outline-none focus:bg-saweria-light">
                        <p class="text-[9px] text-saweria-gray font-semibold">${p.desc}</p>
                    </div>
                `).join('');
            } else {
                paramsContainer.classList.add('hidden');
                paramsForm.innerHTML = "";
            }

            updateInteractivePayloads();

            const drawer = document.getElementById('sandbox-drawer');
            const overlay = document.getElementById('drawer-overlay');
            
            overlay.classList.remove('hidden');
            setTimeout(() => {
                overlay.classList.remove('opacity-0');
                drawer.classList.remove('translate-x-full');
            }, 50);

            document.getElementById('json-output').innerText = '// Klik "Kirim Request" untuk melihat output...';
            lucide.createIcons();
        }

        function closeSandboxDrawer() {
            const drawer = document.getElementById('sandbox-drawer');
            const overlay = document.getElementById('drawer-overlay');

            drawer.classList.add('translate-x-full');
            overlay.classList.add('opacity-0');
            setTimeout(() => {
                overlay.classList.add('hidden');
            }, 300);
        }

        function updateInteractivePayloads() {
            const ep = apiData[activeEndpointIndex];
            let activePath = ep.path;

            ep.params.forEach(p => {
                const inputElement = document.getElementById(`sandbox-input-${p.name}`);
                if (inputElement) {
                    const value = inputElement.value.trim();
                    if (value.length > 0) {
                        if (activePath.includes(`:${p.name}`)) {
                            activePath = activePath.replace(`:${p.name}`, encodeURIComponent(value));
                        } else {
                            const sep = activePath.includes('?') ? '&' : '?';
                            activePath = `${activePath}${sep}${p.name}=${encodeURIComponent(value)}`;
                        }
                    }
                }
            });

            const fullRequestUrl = `${currentHost}${activePath}`;
            document.getElementById('drawer-path-preview').innerText = activePath;

            const curlCode = `curl -X GET "${fullRequestUrl}" \\\n  -H "Accept: application/json"`;
            const jsCode = `import axios from 'axios';\n\naxios.get('${fullRequestUrl}')\n  .then(res => console.log(res.data))\n  .catch(err => console.error(err));`;
            const pythonCode = `import requests\n\nurl = "${fullRequestUrl}"\nresponse = requests.get(url)\nprint(response.json())`;

            document.getElementById('code-curl').innerHTML = highlightCurl(curlCode);
            document.getElementById('code-nodejs').innerHTML = highlightJS(jsCode);
            document.getElementById('code-python').innerHTML = highlightPython(pythonCode);
        }

        function highlightCurl(code) {
            return code
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/\b(curl)\b/g, '<span class="text-[#ff7b72] font-bold">$1</span>')
                .replace(/(-X|-H)/g, '<span class="text-[#79c0ff]">$1</span>')
                .replace(/(".*?")/g, '<span class="text-[#a5d6ff]">$1</span>');
        }

        function highlightJS(code) {
            return code
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/\b(import|from|const|require|let)\b/g, '<span class="text-[#ff7b72] font-bold">$1</span>')
                .replace(/('.*?'|".*?")/g, '<span class="text-[#a5d6ff]">$1</span>')
                .replace(/\b(console|axios)\b/g, '<span class="text-[#79c0ff]">$1</span>')
                .replace(/\b(log|error|get)\b/g, '<span class="text-[#d2a8ff]">$1</span>');
        }

        function highlightPython(code) {
            return code
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/\b(import|print)\b/g, '<span class="text-[#ff7b72] font-bold">$1</span>')
                .replace(/(".*?")/g, '<span class="text-[#a5d6ff]">$1</span>')
                .replace(/\b(requests|response)\b/g, '<span class="text-[#79c0ff]">$1</span>')
                .replace(/\.(get|json)\b/g, '.<span class="text-[#d2a8ff]">$1</span>');
        }

        function switchLanguage(lang) {
            activeLanguage = lang;
            
            document.querySelectorAll('.code-tab').forEach(block => {
                if (block.id === `code-${lang}`) {
                    block.classList.remove('hidden');
                } else {
                    block.classList.add('hidden');
                }
            });

            ['curl', 'nodejs', 'python'].forEach(l => {
                const btn = document.getElementById(`tab-${l}`);
                if (l === lang) {
                    btn.className = "text-[10px] font-mono font-bold px-2.5 py-1 transition-all bg-saweria-dark text-white";
                } else {
                    btn.className = "text-[10px] font-mono font-bold px-2.5 py-1 transition-all text-saweria-gray hover:text-saweria-dark";
                }
            });
        }

        function copyCodeSnippet() {
            const activePre = document.getElementById(`code-${activeLanguage}`);
            const textToCopy = activePre.innerText;

            const textarea = document.createElement("textarea");
            textarea.value = textToCopy;
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand("copy");
            document.body.removeChild(textarea);

            showToastNotification("Copied", "Snippet integrasi kode berhasil disimpan ke clipboard.");
        }

        function showToastNotification(title, message) {
            const toastElement = document.getElementById('toast');
            toastElement.querySelector('p').innerText = title;
            document.getElementById('toast-msg').innerText = message;

            toastElement.classList.remove('translate-y-[-20px]', 'opacity-0');
            toastElement.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                toastElement.classList.add('translate-y-[-20px]', 'opacity-0');
                toastElement.classList.remove('translate-y-0', 'opacity-100');
            }, 3000);
        }

        function executeSandboxRequest() {
            const ep = apiData[activeEndpointIndex];
            const outputBox = document.getElementById('json-output');

            outputBox.innerText = "// Mengirim permintaan GET ke " + currentHost + "...";
            outputBox.className = "text-slate-500 animate-pulse";

            setTimeout(() => {
                let dynamicMock = JSON.parse(JSON.stringify(ep.mockResponse));
                
                ep.params.forEach(p => {
                    const inputVal = document.getElementById(`sandbox-input-${p.name}`)?.value;
                    if (inputVal && inputVal.trim().length > 0) {
                        if (dynamicMock.filter_genre) dynamicMock.filter_genre = inputVal;
                        if (dynamicMock.search_query) dynamicMock.search_query = inputVal;
                    }
                });

                const styledHtml = formatGitHubDarkJSON(dynamicMock);
                outputBox.innerHTML = styledHtml;
                outputBox.className = "gh-dark overflow-y-auto max-h-[250px] leading-relaxed";
                
                showToastNotification("Koneksi Berhasil", "Menerima metadata rute dengan kode status 200 OK.");
            }, 900);
        }

        function formatGitHubDarkJSON(json) {
            if (typeof json !== 'string') {
                json = JSON.stringify(json, null, 2);
            }
            json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+-]?\d+)?)/g, function (match) {
                let cls = 'json-value';
                if (/^"/.test(match)) {
                    if (/:$/.test(match)) {
                        cls = 'json-key';
                    } else {
                        cls = 'json-string';
                    }
                } else if (/true|false/.test(match)) {
                    cls = 'json-boolean';
                } else if (/null/.test(match)) {
                    cls = 'json-null';
                } else if (/\d+/.test(match)) {
                    cls = 'json-number';
                }
                return '<span class="' + cls + '">' + match + '</span>';
            });
        }

        const preloadingProcessSteps = [
            "Parsing API Schemas...",
            "Assembling Saweria Canvas...",
            "Connecting Github API...",
            "Ready to test!"
        ];

        window.onload = function() {
            let stepIndex = 0;
            const loaderText = document.getElementById("loading-text");
            
            const preloadStep = setInterval(() => {
                if (stepIndex < preloadingProcessSteps.length) {
                    loaderText.innerText = preloadingProcessSteps[stepIndex];
                    stepIndex++;
                } else {
                    clearInterval(preloadStep);
                }
            }, 180);

            renderEndpoints();
            loadGithubRepositoryStats();

            setTimeout(() => {
                if (typeof AOS !== 'undefined') {
                    AOS.init({
                        duration: 700,
                        once: true,
                        easing: 'ease-out-quad'
                    });
                }
                
                const loader = document.getElementById("loading-screen");
                loader.style.opacity = "0";
                setTimeout(() => loader.style.display = "none", 600);
            }, 1000);
        };
    </script>
</body>
</html>
