<%- include('partials/header', { title: title, description: description, currentUrl: currentUrl, ogImage: ogImage, ogType: 'website' }) %>

<!-- HERO FEATURED SPOTLIGHT SWIPER SLIDER -->
<% if (slides && slides.length > 0) { %>
<section class="relative neo-card bg-white border-4 border-saweria-dark rounded-[2rem] p-3 sm:p-5 shadow-[6px_6px_0_#1e1e1e] space-y-3" data-aos="fade-up">
    <!-- Header Showcase Bar -->
    <div class="flex items-center justify-between px-1">
        <div class="flex items-center gap-2">
            <span class="px-3 py-1 rounded-full bg-saweria-yellow text-saweria-dark font-extrabold text-[10px] sm:text-xs uppercase tracking-wider border-2 border-saweria-dark shadow-[2px_2px_0_#1e1e1e] flex items-center gap-1.5">
                <i data-lucide="sparkles" class="w-3.5 h-3.5 text-saweria-dark fill-saweria-dark"></i>
                FEATURED SPOTLIGHT
            </span>
            <span class="hidden sm:inline-flex px-3 py-1 rounded-full bg-saweria-light text-saweria-dark font-bold text-[10px] sm:text-xs border-2 border-saweria-dark">
                Rekomendasi Minggu Ini
            </span>
        </div>
        
        <!-- Slide Counter Indicator -->
        <div class="flex items-center gap-1.5 font-mono font-extrabold text-xs bg-saweria-light border-2 border-saweria-dark px-3 py-1 rounded-full shadow-[2px_2px_0_#1e1e1e]">
            <span id="hero-current-slide" class="text-saweria-coral">01</span>
            <span class="text-saweria-gray">/</span>
            <span class="text-saweria-dark"><%= slides.length < 10 ? '0' + slides.length : slides.length %></span>
        </div>
    </div>

    <!-- Swiper Hero Main Container -->
    <div class="relative group/hero overflow-hidden rounded-2xl sm:rounded-3xl border-3 sm:border-4 border-saweria-dark shadow-[4px_4px_0_#1e1e1e] bg-saweria-dark">
        
        <!-- Custom Navigation Arrows (Melayang Elegant) -->
        <button class="hero-prev neo-btn absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-30 w-9 h-9 sm:w-11 sm:h-11 rounded-full bg-white hover:bg-saweria-yellow border-2 sm:border-3 border-saweria-dark text-saweria-dark flex items-center justify-center shadow-[3px_3px_0_#1e1e1e] transition-all opacity-85 group-hover/hero:opacity-100" title="Slide Sebelumnya">
            <i data-lucide="chevron-left" class="w-5 h-5 sm:w-6 sm:h-6 stroke-[2.5]"></i>
        </button>
        <button class="hero-next neo-btn absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-30 w-9 h-9 sm:w-11 sm:h-11 rounded-full bg-white hover:bg-saweria-yellow border-2 sm:border-3 border-saweria-dark text-saweria-dark flex items-center justify-center shadow-[3px_3px_0_#1e1e1e] transition-all opacity-85 group-hover/hero:opacity-100" title="Slide Selanjutnya">
            <i data-lucide="chevron-right" class="w-5 h-5 sm:w-6 sm:h-6 stroke-[2.5]"></i>
        </button>

        <div class="swiper hero-swiper w-full">
            <div class="swiper-wrapper">
                <% slides.forEach((slide, idx) => { 
                    let slug = slide.url ? slide.url.replace(/\/+$/, '').split('/').pop() : '';
                    let watchSlug = slide.watch ? slide.watch.replace(/\/+$/, '').split('/').pop() : slug;
                %>
                <div class="swiper-slide relative">
                    <div class="relative w-full aspect-[16/11] sm:aspect-[21/9] lg:aspect-[2.4/1] overflow-hidden flex items-center">
                        
                        <!-- Backdrop Cover Image -->
                        <img src="<%= slide.image || 'https://via.placeholder.com/1200x675' %>" class="absolute inset-0 w-full h-full object-cover opacity-40 scale-100 group-hover/hero:scale-105 transition-transform duration-1000 ease-out" alt="<%= slide.title %>">
                        
                        <!-- Smooth Vignette Gradient Overlay -->
                        <div class="absolute inset-0 bg-gradient-to-r from-saweria-dark via-saweria-dark/90 to-saweria-dark/30 p-5 sm:p-8 md:p-10 flex items-center justify-between gap-6 z-10">
                            
                            <!-- Main Content Column -->
                            <div class="max-w-2xl space-y-2.5 sm:space-y-4 text-white z-20">
                                
                                <!-- Badges Cluster -->
                                <div class="flex items-center gap-2 flex-wrap">
                                    <span class="px-2.5 py-0.5 sm:px-3 sm:py-1 rounded-full bg-saweria-yellow text-saweria-dark font-extrabold text-[10px] sm:text-xs uppercase border-2 border-saweria-dark shadow-[2px_2px_0_#1e1e1e]">
                                        3D DONGHUA
                                    </span>
                                    <span class="px-2.5 py-0.5 sm:px-3 sm:py-1 rounded-full bg-saweria-green text-saweria-dark font-extrabold text-[10px] sm:text-xs uppercase border-2 border-saweria-dark">
                                        SUB INDO
                                    </span>
                                    <span class="hidden md:inline-flex px-2.5 py-0.5 sm:px-3 sm:py-1 rounded-full bg-saweria-lavender text-saweria-dark font-extrabold text-[10px] sm:text-xs border-2 border-saweria-dark">
                                        HD 1080P
                                    </span>
                                </div>

                                <!-- Title -->
                                <h1 class="font-extrabold text-lg sm:text-2xl md:text-3xl lg:text-4xl text-white tracking-tight drop-shadow-md line-clamp-2 leading-tight">
                                    <%= slide.title %>
                                </h1>

                                <!-- Description -->
                                <% if (slide.description) { %>
                                <p class="hidden sm:block text-xs sm:text-sm font-medium text-saweria-light/90 line-clamp-2 leading-relaxed max-w-xl">
                                    <%= slide.description %>
                                </p>
                                <% } %>

                                <!-- Clean Action Buttons (No Bookmark) -->
                                <div class="flex items-center gap-2.5 sm:gap-3 pt-1">
                                    <a href="/watch/<%= watchSlug %>" class="neo-btn inline-flex items-center gap-2 px-5 py-2 sm:px-6 sm:py-2.5 rounded-full bg-saweria-yellow border-2 sm:border-3 border-saweria-dark text-saweria-dark font-extrabold text-xs sm:text-sm shadow-[3px_3px_0_#1e1e1e]">
                                        <i data-lucide="play" class="w-4 h-4 fill-saweria-dark"></i>
                                        <span>Nonton Sekarang</span>
                                    </a>
                                    <a href="/detail/<%= slug %>" class="neo-btn inline-flex items-center gap-1.5 px-4 py-2 sm:px-5 sm:py-2.5 rounded-full bg-white border-2 sm:border-3 border-saweria-dark text-saweria-dark font-extrabold text-xs sm:text-sm">
                                        <i data-lucide="info" class="w-4 h-4"></i>
                                        <span>Detail Serial</span>
                                    </a>
                                </div>
                            </div>

                            <!-- Right Vertical Poster Preview (Desktop Only) -->
                            <div class="hidden md:block flex-shrink-0 z-20 pr-4">
                                <div class="relative w-32 lg:w-40 aspect-[3/4] rounded-2xl overflow-hidden border-3 border-saweria-dark shadow-[5px_5px_0_#faae2b] bg-saweria-bg group/poster">
                                    <img src="<%= slide.image || 'https://via.placeholder.com/300x400' %>" class="w-full h-full object-cover group-hover/poster:scale-105 transition-transform duration-500" alt="<%= slide.title %>">
                                    <div class="absolute top-2 right-2 bg-saweria-yellow text-saweria-dark text-[9px] font-extrabold px-2 py-0.5 rounded-full border border-saweria-dark shadow-[1px_1px_0_#1e1e1e]">
                                        POPULER
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <% }); %>
            </div>

            <!-- Custom Swiper Pagination Pills -->
            <div class="hero-pagination swiper-pagination !bottom-3 !z-20"></div>
        </div>

        <!-- Progress Line Bar Indicator -->
        <div class="w-full h-1 bg-saweria-dark/80 relative z-20 overflow-hidden">
            <div id="hero-progress-line" class="h-full bg-saweria-yellow transition-all duration-300 w-0"></div>
        </div>
    </div>
</section>
<% } %>

<!-- POPULAR DONGHUA CAROUSEL SLIDER -->
<% if (populars && populars.length > 0) { %>
<section class="space-y-3.5" data-aos="fade-up">
    <!-- Header with Custom Navigation Arrows -->
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-2.5">
            <div class="w-3 h-7 bg-saweria-yellow border-2 border-saweria-dark rounded-md shadow-[2px_2px_0_#1e1e1e]"></div>
            <div>
                <h2 class="font-extrabold text-lg sm:text-2xl text-saweria-dark tracking-tight">Donghua Populer</h2>
                <p class="text-[11px] font-semibold text-saweria-gray hidden sm:block">Serial favorit pilihan penonton minggu ini</p>
            </div>
        </div>

        <div class="flex items-center gap-2">
            <!-- Swiper Custom Nav Buttons -->
            <div class="flex items-center gap-1">
                <button class="popular-prev neo-btn p-1.5 sm:p-2 rounded-full bg-white hover:bg-saweria-yellow border-2 border-saweria-dark text-saweria-dark" title="Sebelumnya">
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                </button>
                <button class="popular-next neo-btn p-1.5 sm:p-2 rounded-full bg-white hover:bg-saweria-yellow border-2 border-saweria-dark text-saweria-dark" title="Selanjutnya">
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </button>
            </div>
            
            <a href="/popular" class="neo-btn px-3.5 py-1.5 rounded-full bg-saweria-light border-2 border-saweria-dark text-xs font-extrabold text-saweria-dark flex items-center gap-1 ml-1">
                <span>Semua</span> &rarr;
            </a>
        </div>
    </div>

    <!-- Swiper Popular Slider -->
    <div class="swiper popular-swiper pb-4 overflow-hidden w-full max-w-full">
        <div class="swiper-wrapper">
            <% populars.forEach(item => { 
                let slug = item.href ? item.href.replace(/\/+$/, '').split('/').pop() : '';
            %>
            <div class="swiper-slide p-1">
                <div class="neo-card bg-white border-3 border-saweria-dark rounded-2xl p-2.5 space-y-2 flex flex-col h-full neo-card-hover group">
                    <div class="relative aspect-[3/4] rounded-xl overflow-hidden border-2 border-saweria-dark bg-saweria-bg flex-shrink-0">
                        <img src="<%= item.image || 'https://via.placeholder.com/300x400' %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" alt="<%= item.title %>">
                        
                        <% if (item.ep) { %>
                        <span class="absolute top-1.5 left-1.5 bg-saweria-yellow text-saweria-dark font-extrabold text-[9px] px-2 py-0.5 rounded-full border border-saweria-dark shadow-[1px_1px_0_#1e1e1e]">
                            <%= item.ep %>
                        </span>
                        <% } %>

                        <% if (item.status) { %>
                        <span class="absolute bottom-1.5 right-1.5 bg-saweria-green text-saweria-dark font-extrabold text-[9px] px-2 py-0.5 rounded-full border border-saweria-dark">
                            <%= item.status %>
                        </span>
                        <% } %>

                        <!-- Play Button Overlay on Hover -->
                        <div class="absolute inset-0 bg-saweria-dark/30 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                            <div class="w-10 h-10 rounded-full bg-saweria-yellow border-2 border-saweria-dark flex items-center justify-center shadow-[2px_2px_0_#1e1e1e] transform scale-75 group-hover:scale-100 transition-transform">
                                <i data-lucide="play" class="w-5 h-5 fill-saweria-dark text-saweria-dark"></i>
                            </div>
                        </div>
                    </div>

                    <div class="flex-1 flex flex-col justify-between space-y-2">
                        <a href="/detail/<%= slug %>" class="font-extrabold text-xs text-saweria-dark group-hover:text-saweria-coral line-clamp-2 leading-tight">
                            <%= item.title %>
                        </a>
                        <div class="pt-1.5 flex items-center justify-between border-t border-saweria-dark/10">
                            <a href="/detail/<%= slug %>" class="neo-btn w-full text-center py-1.5 rounded-xl bg-saweria-yellow border-2 border-saweria-dark text-[10px] font-extrabold text-saweria-dark">
                                Lihat Detail
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>
<% } %>

<!-- LATEST EPISODES GRID -->
<% if (latests && latests.length > 0) { %>
<section class="space-y-4" data-aos="fade-up">
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
            <div class="w-3 h-7 bg-saweria-coral border-2 border-saweria-dark rounded-md shadow-[2px_2px_0_#1e1e1e]"></div>
            <div>
                <h2 class="font-extrabold text-lg sm:text-2xl text-saweria-dark tracking-tight">Rilisan Episode Terbaru</h2>
                <p class="text-[11px] font-semibold text-saweria-gray hidden sm:block">Update setiap hari langsung dengan Subtitle Indonesia</p>
            </div>
        </div>
        <a href="/latest" class="neo-btn px-3.5 py-1.5 rounded-full bg-saweria-light border-2 border-saweria-dark text-xs font-extrabold text-saweria-dark flex items-center gap-1">
            <span>Lihat Semua</span> &rarr;
        </a>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3.5 sm:gap-4">
        <% latests.forEach(item => { 
            let slug = item.href ? item.href.replace(/\/+$/, '').split('/').pop() : '';
        %>
        <div class="neo-card bg-white border-3 border-saweria-dark rounded-2xl p-2.5 space-y-2 flex flex-col h-full neo-card-hover group">
            <div class="relative aspect-[3/4] rounded-xl overflow-hidden border-2 border-saweria-dark bg-saweria-bg flex-shrink-0">
                <img src="<%= item.image || 'https://via.placeholder.com/300x400' %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" alt="<%= item.title %>">
                
                <% if (item.ep) { %>
                <span class="absolute top-1.5 left-1.5 bg-saweria-yellow text-saweria-dark font-extrabold text-[9px] px-2 py-0.5 rounded-full border border-saweria-dark shadow-[1px_1px_0_#1e1e1e]">
                    <%= item.ep %>
                </span>
                <% } %>

                <% if (item.type) { %>
                <span class="absolute top-1.5 right-1.5 bg-saweria-pink text-saweria-dark font-extrabold text-[9px] px-1.5 py-0.5 rounded-full border border-saweria-dark">
                    <%= item.type %>
                </span>
                <% } %>
            </div>

            <div class="flex-1 flex flex-col justify-between space-y-2">
                <a href="/watch/<%= slug %>" class="font-extrabold text-xs text-saweria-dark group-hover:text-saweria-coral line-clamp-2 leading-tight">
                    <%= item.title %>
                </a>
                
                <div class="grid grid-cols-2 gap-1.5 pt-1.5 border-t border-saweria-dark/10">
                    <a href="/watch/<%= slug %>" class="neo-btn text-center py-1.5 rounded-xl bg-saweria-yellow border-2 border-saweria-dark text-[10px] font-extrabold text-saweria-dark flex items-center justify-center gap-1">
                        <i data-lucide="play" class="w-3 h-3 fill-saweria-dark"></i> Nonton
                    </a>
                    <a href="/detail/<%= slug.replace(/-episode-\d+.*$/, '') %>" class="neo-btn text-center py-1.5 rounded-xl bg-saweria-light border-2 border-saweria-dark text-[10px] font-extrabold text-saweria-dark flex items-center justify-center">
                        Detail
                    </a>
                </div>
            </div>
        </div>
        <% }); %>
    </div>
</section>
<% } %>

<!-- QUICK GENRES CLUSTER -->
<% if (genres && genres.length > 0) { %>
<section class="space-y-3" data-aos="fade-up">
    <div class="flex items-center gap-2.5">
        <div class="w-3 h-7 bg-saweria-lavender border-2 border-saweria-dark rounded-md shadow-[2px_2px_0_#1e1e1e]"></div>
        <h2 class="font-extrabold text-lg sm:text-2xl text-saweria-dark tracking-tight">Kategori Genre Populer</h2>
    </div>

    <div class="flex items-center gap-2 flex-wrap">
        <% genres.slice(0, 18).forEach(g => { %>
        <a href="/genres/<%= g.slug %>" class="neo-btn px-3.5 py-1.5 rounded-full border-2 border-saweria-dark bg-white hover:bg-saweria-yellow text-xs font-extrabold text-saweria-dark transition-colors">
            # <%= g.name %>
        </a>
        <% }); %>
    </div>
</section>
<% } %>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof Swiper !== 'undefined') {
            const heroProgressLine = document.getElementById('hero-progress-line');
            const heroCurrentSlide = document.getElementById('hero-current-slide');

            function startHeroProgress() {
                if (!heroProgressLine) return;
                heroProgressLine.style.transition = 'none';
                heroProgressLine.style.width = '0%';
                setTimeout(() => {
                    heroProgressLine.style.transition = 'width 5000ms linear';
                    heroProgressLine.style.width = '100%';
                }, 50);
            }

            // Hero Swiper Initialization
            const heroSwiper = new Swiper('.hero-swiper', {
                loop: true,
                speed: 800,
                effect: 'fade',
                fadeEffect: { crossFade: true },
                autoplay: {
                    delay: 5000,
                    disableOnInteraction: false,
                    pauseOnMouseEnter: true
                },
                pagination: {
                    el: '.hero-pagination',
                    clickable: true
                },
                navigation: {
                    nextEl: '.hero-next',
                    prevEl: '.hero-prev'
                },
                on: {
                    init: function () {
                        startHeroProgress();
                    },
                    slideChange: function () {
                        startHeroProgress();
                        if (heroCurrentSlide) {
                            let realIdx = this.realIndex + 1;
                            heroCurrentSlide.innerText = realIdx < 10 ? '0' + realIdx : realIdx;
                        }
                    }
                }
            });

            // Popular Donghua Swiper Initialization
            new Swiper('.popular-swiper', {
                slidesPerView: 2,
                spaceBetween: 14,
                speed: 600,
                navigation: {
                    nextEl: '.popular-next',
                    prevEl: '.popular-prev'
                },
                breakpoints: {
                    640: { slidesPerView: 3, spaceBetween: 16 },
                    768: { slidesPerView: 4, spaceBetween: 18 },
                    1024: { slidesPerView: 5, spaceBetween: 20 }
                }
            });
        }
    });
</script>

<%- include('partials/footer') %>
