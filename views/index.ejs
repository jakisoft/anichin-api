    <div id="toast" class="fixed top-6 right-6 z-50 transform translate-y-[-20px] opacity-0 transition-all duration-300 pointer-events-none bg-white border-4 border-saweria-dark text-saweria-dark px-5 py-4 rounded-none shadow-[4px_4px_0px_0px_#1e1e1e] flex items-center gap-3">
