<%- include('partials/header', { title: title, description: description, currentUrl: currentUrl, ogImage: ogImage, ogType: 'website' }) %>

<section class="space-y-4" data-aos="fade-up">
    <!-- Breadcrumb Path Navigation -->
    <nav class="flex items-center gap-1.5 sm:gap-2 text-xs font-extrabold text-saweria-dark bg-white border-2 border-saweria-dark px-3.5 sm:px-4 py-2 rounded-2xl shadow-[2px_2px_0_#1e1e1e] w-full max-w-full flex-wrap overflow-hidden leading-normal">
        <a href="/" class="hover:text-saweria-coral flex items-center gap-1 transition-colors flex-shrink-0">
            <i data-lucide="home" class="w-3.5 h-3.5"></i> Beranda
        </a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-saweria-gray flex-shrink-0"></i>
        <span class="text-saweria-coral flex items-center gap-1 font-black max-w-[180px] sm:max-w-[280px] truncate">
            <i data-lucide="history" class="w-3.5 h-3.5 flex-shrink-0"></i> Riwayat Nonton
        </span>
    </nav>
    <!-- Title Banner -->
    <div class="neo-card bg-saweria-green border-4 border-saweria-dark rounded-3xl p-5 sm:p-6 text-saweria-dark space-y-1">
        <div class="flex items-center justify-between gap-3">
            <div>
                <h1 class="text-xl sm:text-2xl font-extrabold flex items-center gap-2">
                    <i data-lucide="history" class="w-6 h-6"></i> Riwayat Nonton
                </h1>
                <p class="text-xs font-bold text-saweria-dark/80">Daftar episode Donghua yang pernah Anda tonton sebelumnya.</p>
            </div>
            <button onclick="clearHistory()" class="neo-btn px-3 py-1.5 rounded-full bg-saweria-pink border-2 border-saweria-dark text-xs font-extrabold text-saweria-dark flex items-center gap-1">
                <i data-lucide="trash" class="w-3.5 h-3.5"></i> Hapus Riwayat
            </button>
        </div>
    </div>

    <!-- Container Rendered by JS from LocalStorage -->
    <div id="history-container" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3.5 sm:gap-4"></div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const list = getHistory();
        const container = document.getElementById('history-container');

        if (list && list.length > 0) {
            container.innerHTML = list.map(item => `
                <div class="neo-card bg-white border-3 border-saweria-dark rounded-2xl p-2.5 space-y-2 flex flex-col h-full neo-card-hover group">
                    <div class="relative aspect-[3/4] rounded-xl overflow-hidden border-2 border-saweria-dark bg-saweria-bg flex-shrink-0">
                        <img src="${item.image || 'https://via.placeholder.com/300x400'}" class="w-full h-full object-cover group-hover:scale-105 transition-transform" alt="${item.title}">
                        ${item.episode ? `<span class="absolute top-1.5 left-1.5 bg-saweria-yellow text-saweria-dark font-extrabold text-[9px] px-2 py-0.5 rounded-full border border-saweria-dark shadow-sm">Ep ${item.episode}</span>` : ''}
                    </div>
                    <a href="/watch/${item.slug}" class="font-extrabold text-xs text-saweria-dark group-hover:text-saweria-coral line-clamp-2 leading-tight flex-1">
                        ${item.title}
                    </a>
                    <a href="/watch/${item.slug}" class="neo-btn w-full text-center py-1 rounded-xl bg-saweria-green border-2 border-saweria-dark text-[10px] font-extrabold text-saweria-dark block mt-2">
                        Lanjut Nonton
                    </a>
                </div>
            `).join('');
            lucide.createIcons();
        } else {
            container.className = 'block';
            container.innerHTML = `
                <div class="neo-card bg-white border-4 border-saweria-dark rounded-3xl p-8 text-center space-y-3 max-w-md mx-auto">
                    <i data-lucide="clock" class="w-10 h-10 text-saweria-gray mx-auto"></i>
                    <h3 class="text-base font-extrabold text-saweria-dark">Belum Ada Riwayat Nonton</h3>
                    <p class="text-xs font-bold text-saweria-gray">Episode Donghua yang Anda putar akan tercatat secara otomatis di sini.</p>
                    <a href="/popular" class="neo-btn inline-block px-5 py-2 rounded-full bg-saweria-yellow border-2 border-saweria-dark text-xs font-extrabold text-saweria-dark">
                        Mulai Nonton
                    </a>
                </div>
            `;
            lucide.createIcons();
        }
    });

    function clearHistory() {
        if (confirm('Apakah Anda yakin ingin menghapus seluruh riwayat menonton?')) {
            localStorage.removeItem('anichin_history');
            location.reload();
        }
    }
</script>

<%- include('partials/footer') %>
